                "tags": [
                    "System"
                ],
                "summary": "Health check endpoint",
                "operationId": "apiHealth",
                "responses": {
                    "200": {
                        "description": "System health response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "service": {
                                            "type": "string",
                                            "example": "college-backend"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "example": "2026-04-25 12:00:00"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/posts": {
            "post": {
                "tags": [
                    "Posts"
                ],
                "summary": "Create a post (web auth + role protected)",
                "description": "Creates a new post from admin panel request payload.",
                "operationId": "adminCreatePost",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "body",
                                    "status"
                                ],
                                "properties": {
